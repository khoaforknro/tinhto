<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Gửi Cậu...</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@500&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body, html {
            width: 100%;
            height: 100%;
            overflow: hidden;
            background-color: #000;
            font-family: 'Lexend', sans-serif;
        }

        #rotate-message {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: #000;
            color: #fff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 999;
            text-align: center;
            font-size: 1.2rem;
            padding: 20px;
        }
        
        .phone-icon {
            width: 50px;
            height: 80px;
            border: 3px solid #fff;
            border-radius: 10px;
            margin-bottom: 20px;
            animation: rotatePhone 2s infinite ease-in-out;
            position: relative;
        }
        .phone-icon::after {
            content: '';
            position: absolute;
            bottom: 5px; left: 50%;
            transform: translateX(-50%);
            width: 8px; height: 8px;
            background: #fff;
            border-radius: 50%;
        }
        @keyframes rotatePhone {
            0% { transform: rotate(0deg); }
            50% { transform: rotate(-90deg); }
            100% { transform: rotate(-90deg); }
        }

        #main-content {
            display: none;
            position: relative;
            width: 100%;
            height: 100%;
        }
        canvas {
            display: block;
            position: absolute;
            top: 0; left: 0;
            z-index: 1;
        }

        .text-overlay {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 2;
        }
        
        .message {
            font-family: 'Lexend', sans-serif !important;
            color: #ff69b4;
            font-size: 5rem; /* Kích thước chữ lớn nhưng thanh mảnh nên không bị thô */
            font-weight: 500; /* Độ dày vừa phải, tạo nét thanh thoát */
            letter-spacing: 1px; /* Giãn chữ nhẹ giúp dễ đọc và sang hơn */
            /* Đổ bóng nhẹ nhàng tinh tế, không bị quá chói */
            text-shadow: 0 0 15px rgba(255, 20, 147, 0.8), 0 0 30px rgba(255, 105, 180, 0.6); 
            opacity: 0;
            transition: opacity 0.8s ease-in-out, transform 0.8s ease-in-out;
            transform: scale(0.85); /* Hiệu ứng hiện ra mượt mà, nhẹ nhàng */
            text-align: center;
            max-width: 85%;
        }
        .message.active {
            opacity: 1;
            transform: scale(1);
        }
        
        .heart {
            font-size: 6rem;
            color: #ff1493;
            animation: beat 0.6s infinite alternate;
            margin-bottom: 15px;
        }
        @keyframes beat {
            to { transform: scale(1.1); }
        }

        @media screen and (orientation: landscape) {
            #rotate-message { display: none; }
            #main-content { display: block; }
        }
    </style>
</head>
<body>

    <div id="rotate-message">
        <div class="phone-icon"></div>
        <p>Vui lòng xoay ngang thiết bị của bạn</p>
    </div>

    <div id="main-content">
        <canvas id="matrixCanvas"></canvas>
        <div class="text-overlay">
            <div id="text-display" class="message"></div>
        </div>
    </div>

    <script>
        const canvas = document.getElementById('matrixCanvas');
        const ctx = canvas.getContext('2d');

        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        resizeCanvas();
        window.addEventListener('resize', resizeCanvas);

        const letters = "love❤️🌸✨youforeveramoursilence";
        const fontSize = 16;
        let columns = canvas.width / fontSize;
        let drops = Array(Math.floor(columns)).fill(1);

        window.addEventListener('resize', () => {
            columns = canvas.width / fontSize;
            drops = Array(Math.floor(columns)).fill(1);
        });

        function drawMatrix() {
            ctx.fillStyle = "rgba(0, 0, 0, 0.05)";
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            ctx.fillStyle = "rgba(255, 105, 180, 0.25)";
            ctx.font = fontSize + "px monospace";

            for (let i = 0; i < drops.length; i++) {
                const text = letters[Math.floor(Math.random() * letters.length)];
                ctx.fillText(text, i * fontSize, drops[i] * fontSize);

                if (drops[i] * fontSize > canvas.height && Math.random() > 0.975) {
                    drops[i] = 0;
                }
                drops[i]++;
            }
        }
        setInterval(drawMatrix, 33);

        // KỊCH BẢN CHỮ (Viết chữ thường có dấu bình thường cho nhẹ nhàng)
        const script = [
            { text: "3", duration: 1000 },
            { text: "2", duration: 1000 },
            { text: "1", duration: 1000 },
            { text: "Em đồng ý...", duration: 2500 },
            { text: "Làm người yêu", duration: 2500 },
            { text: "Anh nhé? ", duration: 2500 },
            { text: "<div class='heart'>❤️</div><span style='font-size: 3.8rem; display:block; font-weight: 500;'>Anh yêu em</span>", duration: 5000 }
        ];

        const textDisplay = document.getElementById('text-display');
        let currentStep = 0;

        function runScript() {
            if (currentStep < script.length) {
                const step = script[currentStep];
                
                if(currentStep === script.length - 1) {
                    textDisplay.style.fontSize = "3.8rem";
                } else {
                    textDisplay.style.fontSize = "5rem";
                }
                
                textDisplay.innerHTML = step.text;
                textDisplay.classList.add('active');

                setTimeout(() => {
                    textDisplay.classList.remove('active');
                    setTimeout(() => {
                        currentStep++;
                        runScript();
                    }, 800); 
                }, step.duration);
            }
        }

        let started = false;
        function checkOrientation() {
            if (window.innerWidth > window.innerHeight && !started) {
                started = true;
                setTimeout(runScript, 500); 
            }
        }
        
        window.addEventListener('resize', checkOrientation);
        window.addEventListener('load', checkOrientation);
    </script>
</body>
</html>
